---
import { getGlossaryEntry, type GlossaryId } from '../../data/glossary';

interface Props {
  id: GlossaryId;
  label?: string;
  showEnglish?: boolean;
}

const { id, label, showEnglish = true } = Astro.props;
const entry = getGlossaryEntry(id);
const visibleLabel = label ?? (showEnglish ? `${entry.term}（${entry.english}）` : entry.term);
---

<span class="term-peek">
  <dfn tabindex="0" aria-label={`${entry.term}，${entry.english}`}>{visibleLabel}</dfn>
  <span class="term-peek__panel">
    <span class="term-peek__heading">
      <strong>{entry.term}</strong>
      <small>{entry.english}</small>
    </span>
    <span>{entry.definition}</span>
    <a href={`/glossary/#${entry.id}`}>打开术语条目 →</a>
  </span>
</span>

<style>
  .term-peek {
    position: relative;
    display: inline;
  }

  .term-peek dfn {
    border-bottom: 1px dashed var(--sl-color-accent);
    color: var(--sl-color-accent-high);
    font-style: normal;
    font-weight: 650;
    cursor: help;
    text-decoration: none;
  }

  .term-peek dfn:focus-visible {
    border-radius: 0.15rem;
    outline: 3px solid var(--sl-color-accent-low);
    outline-offset: 2px;
  }

  .term-peek__panel {
    position: absolute;
    z-index: 20;
    inset-block-start: calc(100% + 0.55rem);
    inset-inline-start: 0;
    display: grid;
    width: min(20rem, calc(100vw - 2rem));
    gap: 0.5rem;
    padding: 0.8rem 0.9rem;
    border: 1px solid var(--sl-color-gray-4);
    border-radius: 0.6rem;
    color: var(--sl-color-text);
    background: var(--sl-color-bg);
    box-shadow: 0 16px 38px rgb(15 23 42 / 16%);
    font-size: 0.82rem;
    line-height: 1.55;
    opacity: 0;
    visibility: hidden;
    pointer-events: auto;
    transform: translateY(-0.2rem);
    transition:
      opacity 130ms ease 180ms,
      transform 130ms ease 180ms,
      visibility 0s linear 310ms;
  }

  .term-peek__panel::before {
    position: absolute;
    inset-inline: 0;
    inset-block-end: 100%;
    height: 0.7rem;
    content: '';
  }

  .term-peek__heading {
    display: flex;
    align-items: baseline;
    gap: 0.45rem;
  }

  .term-peek__heading small {
    color: var(--sl-color-gray-2);
    font-family: var(--sl-font-mono);
  }

  .term-peek__panel a {
    width: fit-content;
    color: var(--sl-color-accent-high);
    font-size: 0.75rem;
    font-weight: 700;
  }

  .term-peek:hover .term-peek__panel,
  .term-peek:focus-within .term-peek__panel {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0);
    transition-delay: 0ms;
  }

  @media (max-width: 38rem) {
    .term-peek__panel {
      position: fixed;
      inset: auto 1rem 1rem;
      width: auto;
      transform: translateY(0.4rem);
    }

    .term-peek:hover .term-peek__panel,
    .term-peek:focus-within .term-peek__panel {
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .term-peek__panel { transition: none; }
  }
</style>
