{
  "name": "ai-engineering-learning-terminal",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "audit:public": "tsx scripts/audit-public-content.ts",
    "verify:snippets": "tsx scripts/verify-course-snippets.ts",
    "lab:cache": "tsx examples/cache-reuse-consistency/cache-reuse-simulator.ts --manifest examples/cache-reuse-consistency/cache-workload.json --out artifacts/cache-reuse/report.json --markdown artifacts/cache-reuse/report.md --self-test",
    "gate": "pnpm check && pnpm test && pnpm verify:snippets && pnpm build && pnpm audit:public && pnpm test:e2e",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/preact": "^6.0.1",
    "@astrojs/starlight": "^0.41.3",
    "astro": "^7.0.2",
    "preact": "^10.29.7",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-remark": "7.2.1",
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/preact": "^3.2.4",
    "@types/node": "24.13.3",
    "jsdom": "^27.0.0",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
